APP_NAME=OPD-Vertex
APP_ENV=development
DEBUG=true
SECRET_KEY=pass
HOST=0.0.0.0
PORT=8000

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=opd_vertex
MYSQL_USER=opd_user
MYSQL_PASSWORD=opd_password

MONGO_URI=mongodb://localhost:27017
MONGO_DB=opd_vertex

OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_ENDPOINT=http://localhost:11434
WHISPER_API_URL=http://localhost:8001
WHISPER_MODEL_NAME=large-v3
LLM_MODEL_NAME=qwen3:8b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2200
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
SEED_PROMPTS_ON_STARTUP=true
SEED_MOCK_CONSULTATIONS_ON_STARTUP=true

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.local

PDF_OUTPUT_DIR=./storage/pdfs
TRANSCRIPTS_DIR=./storage/transcripts
GENERATED_DOCS_DIR=./storage/generated

LOG_LEVEL=INFO
USE_MOCK_ADAPTERS=true
